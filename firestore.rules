rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {username}
    // Fields:
    //   - username: string (required) - Unique username
    //   - passwordHash: string (required) - Hashed password
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'passwordHash', 'createdAt']) &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.passwordHash is string && data.passwordHash.size() > 0 &&
             data.createdAt is timestamp;
    }

    match /users/{username} {
      // Allow reading any user document (to check if username exists)
      allow get: if true;
      
      // Allow creation only if authenticated and the document ID matches the username
      // We also validate the schema.
      allow create: if request.auth != null && 
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.username.size() >= 3 &&
                      request.resource.data.username.size() <= 20;
      
      // Only the owner can update or delete their document
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      
      allow list: if false;
    }
  }
}
