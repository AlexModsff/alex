rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {username}
    // Fields:
    //   - username: string (required) - Unique username
    //   - passwordHash: string (required) - Hashed password
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'passwordHash', 'createdAt']) &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.passwordHash is string && data.passwordHash.size() > 0 &&
             data.createdAt is timestamp;
    }

    match /users/{username} {
      // Only allow reading a specific user document (for login check)
      // and creating a new one (registration).
      // We use request.auth == null because our server-side client is unauthenticated
      // but we validate the schema strictly.
      allow get: if true; 
      allow create: if isValidUser(request.resource.data) && 
                      request.resource.id == request.resource.data.username &&
                      request.resource.data.username.size() >= 3 &&
                      request.resource.data.username.size() <= 20;
      
      // Prevent any other access
      allow list, update, delete: if false;
    }
  }
}
