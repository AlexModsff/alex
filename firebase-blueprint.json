{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Unique username"
        },
        "passwordHash": {
          "type": "string",
          "description": "Hashed password"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        }
      },
      "required": ["username", "passwordHash", "createdAt"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "Collection of users indexed by username"
    }
  }
}
