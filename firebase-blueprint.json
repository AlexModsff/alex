{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data including balance and status.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Authentication UID"
        },
        "username": {
          "type": "string",
          "description": "Display name of the user"
        },
        "saldo": {
          "type": "number",
          "description": "User's available balance"
        },
        "esCliente": {
          "type": "boolean",
          "description": "Whether the user is a verified customer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user document was created"
        }
      },
      "required": ["uid", "username", "saldo", "esCliente", "createdAt"]
    }
  },
  "firestore": {
    "/usuarios/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles indexed by their Auth UID"
    }
  }
}
